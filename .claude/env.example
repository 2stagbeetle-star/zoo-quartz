# Zoo Knowledge Vault - 環境変数設定例
# このファイルをコピーして ~/.env を作成し、実際のキーを記入すること
# ~/.env は .gitignore に追加して絶対にコミットしないこと

# Gemini API キー（インフォグラフィック生成に使用）
# 取得先: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# GitHub Personal Access Token（デプロイに使用）
# 取得先: https://github.com/settings/tokens
# 必要権限: repo（リポジトリ操作）, workflow（GitHub Actions）
GITHUB_TOKEN=ghp_...
